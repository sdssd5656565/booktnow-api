# BookTNow backend — environment variables (Render)
# In Render UI: Dashboard → booktnow-api → Environment → Add Environment Variable

NODE_ENV=production

# Render injects PORT automatically. Do NOT set it manually.
# PORT=10000

# Allowed CORS origins (comma-separated). The frontend domain MUST be listed.
CORS_ORIGINS=https://booktnow.com,https://www.booktnow.com

# Demo mode — canned AI responses safe for partner demos.
DEMO_MODE=true
